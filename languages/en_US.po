#: template-parts/sections/about-hero.php:4
msgid "YIARI berdiri untuk memberikan perlindungan, rehabilitasi, dan kesempatan kedua bagi satwa liar Indonesia yang terancam. Dari penyelamatan darurat hingga pelepasliaran kembali ke habitat alami."
msgstr "YIARI exists to provide protection, rehabilitation, and a second chance for threatened Indonesian wildlife, from emergency rescue to release back into their natural habitat."

#: template-parts/sections/about-hero.php:14
msgid "About YIARI"
msgstr "About YIARI"

#: template-parts/sections/about-org.php:4
msgid "Didukung oleh pengurus dan profesional berpengalaman untuk memastikan tata kelola yang efektif dan berintegritas."
msgstr "Supported by experienced board members and professionals to ensure effective and accountable governance."

#: template-parts/sections/about-org.php:8
msgid "Pembina Yayasan"
msgstr "Foundation Trustees"

#: template-parts/sections/about-org.php:9
msgid "Pengawas Yayasan"
msgstr "Foundation Supervisors"

#: template-parts/sections/about-org.php:9
msgid "Ketua Pengawas"
msgstr "Chief Supervisor"

#: template-parts/sections/about-org.php:9
msgid "Pengawas"
msgstr "Supervisor"

#: template-parts/sections/about-timeline.php:4
msgid "Setiap aksi yang kami lakukan menghasilkan perubahan nyata: satwa diselamatkan, dipulihkan, dan kembali ke alamnya."
msgstr "Every action we take creates real change: wildlife is rescued, rehabilitated, and returned to the wild."

#: template-parts/sections/about-timeline.php:8
msgid "Awal Fasilitas"
msgstr "Facility Beginnings"

#: template-parts/sections/about-timeline.php:8
msgid "Pusat rehabilitasi primata di Ciapus, Bogor didirikan khusus untuk kukang dan makaka, sekaligus menjadi pusat rehabilitasi kukang pertama di Indonesia."
msgstr "A primate rehabilitation center in Ciapus, Bogor was established for slow lorises and macaques, becoming Indonesia's first slow loris rehabilitation center."

#: template-parts/sections/about-timeline.php:9
msgid "Status Legal"
msgstr "Legal Status"

#: template-parts/sections/about-timeline.php:9
msgid "YIARI resmi mendapat status legal dan mulai menolong lebih banyak satwa liar Indonesia."
msgstr "YIARI officially received legal status and began helping more Indonesian wildlife."

#: template-parts/sections/about-timeline.php:10
msgid "Ekspansi Rehabilitasi"
msgstr "Rehabilitation Expansion"

#: template-parts/sections/about-timeline.php:10
msgid "Pusat rehabilitasi orangutan di Ketapang berdiri lengkap dengan fasilitas medis dan kawasan hutan seluas ±200 hektar."
msgstr "An orangutan rehabilitation center in Ketapang was established with medical facilities and approximately 200 hectares of forest area."

#: template-parts/sections/about-timeline.php:11
msgid "Pusat Pembelajaran"
msgstr "Learning Center"

#: template-parts/sections/about-timeline.php:11
msgid "Pusat pembelajaran di Kalimantan diresmikan dengan fasilitas lengkap untuk pelatihan, lokakarya, dan edukasi."
msgstr "A learning center in Kalimantan was inaugurated with complete facilities for training, workshops, and education."

#: template-parts/sections/about-vision.php:3
msgid "Visi &amp; Misi YIARI"
msgstr "YIARI Vision &amp; Mission"

#: template-parts/sections/about-vision.php:6
msgid "Dunia tempat manusia dan satwa hidup berdampingan dalam ekosistem yang sehat."
msgstr "A world where humans and wildlife coexist in a healthy ecosystem."

#: template-parts/sections/about-vision.php:8
msgid "Membangun kesadaran dan kepedulian serta mengimplementasikan sistem yang efektif yang melindungi satwa dan habitatnya."
msgstr "To build awareness and care while implementing effective systems that protect wildlife and their habitats."

#: template-parts/sections/about-vision.php:16
msgid "Orangutan dalam perawatan tim YIARI"
msgstr "Orangutan in the care of the YIARI team"

